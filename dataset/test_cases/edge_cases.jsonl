// FitMind Agent 边界与对抗用例
// 跨能力测试，包含歧义、矛盾、自纠错、中英混合等场景

{"test_id":"EDG-001","category":"edge_case","subcategory":"ambiguous","input":"深蹲","expected":{"intent_type":"unknown"},"evaluation_mode":"exact","notes":"单个词无上下文，无法判断是计划、结果还是查询。应返回 unknown 并请求澄清。","tags":["single_word","no_context"]}
{"test_id":"EDG-002","category":"edge_case","subcategory":"conflicting","input":"今天练腿，但是没去健身房，在家做了徒手深蹲","expected":{"intent_type":"workout","facts":[{"fact_type":"completed_exercise","raw_text":"徒手深蹲","normalized_payload":{"exercise_name":"深蹲","weight_kg":0}}]},"evaluation_mode":"fuzzy","notes":"'练腿' 信号 vs '没去健身房' 否定。整体是居家徒手训练。","tags":["negation","bodyweight","home_workout"]}
{"test_id":"EDG-003","category":"edge_case","subcategory":"adversarial","input":"今天练胸卧推，不是，今天练背，做了引体向上和划船","expected":{"facts":[{"fact_type":"completed_exercise","raw_text":"引体向上"},{"fact_type":"completed_exercise","raw_text":"划船"}]},"evaluation_mode":"fuzzy","notes":"消息内有自纠错。Agent 不得提取 '卧推'。","tags":["self_correction","mid_message"]}
{"test_id":"EDG-004","category":"edge_case","subcategory":"adversarial","input":"今天吃了蛋白粉，但是没有训练，因为睡了12小时还是累","expected":{"intent_bundle":["nutrition","body_status"],"facts":[{"fact_type":"supplement","raw_text":"蛋白粉"},{"fact_type":"sleep","raw_text":"睡了12小时"},{"fact_type":"fatigue","raw_text":"还是累"}]},"evaluation_mode":"partial","tags":["supplement_without_workout","sleep_and_fatigue"]}
{"test_id":"EDG-005","category":"edge_case","subcategory":"adversarial","input":"练胸：bench press 185lbs 5x5，incline db press 55lbs 4x10，cable fly 30lbs 3x15，最后cardio 20min","expected":{"facts":[{"fact_type":"completed_exercise","raw_text":"bench press 185lbs 5x5","normalized_payload":{"exercise_name":"卧推","weight_kg":84,"sets":5,"reps":5}},{"fact_type":"completed_exercise","raw_text":"incline db press 55lbs 4x10","normalized_payload":{"exercise_name":"上斜哑铃推举","weight_kg":25,"sets":4,"reps":10}},{"fact_type":"completed_exercise","raw_text":"cable fly 30lbs 3x15","normalized_payload":{"exercise_name":"绳索夹胸","weight_kg":13.6,"sets":3,"reps":15}},{"fact_type":"completed_cardio","raw_text":"cardio 20min","normalized_payload":{"duration_minutes":20}}]},"evaluation_mode":"fuzzy","notes":"中英混合 + 英制单位(lbs)。系统应转换为 kg。1lb = 0.4536kg。","tags":["mixed_language","imperial_units","conversion"]}
