FITMIND_APP_NAME=FitMind Agent
FITMIND_ENV=local
FITMIND_DEBUG=true
FITMIND_API_PREFIX=/api/v1
FITMIND_WEB_ORIGIN=http://localhost:5173
FITMIND_DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/fitmind?charset=utf8mb4
FITMIND_LLM_API_KEY=
FITMIND_LLM_BASE_URL=https://api.deepseek.com
FITMIND_LLM_MODEL=deepseek-v4-flash
FITMIND_LLM_TEMPERATURE=0.7
FITMIND_RECENT_CONTEXT_ROUNDS=5
FITMIND_SUMMARY_COMPRESSION_WORKERS=2
